import random
import math

nodes = [(12,12), (23,12), (33,54)]

N = len(nodes)

dist = [[0]*N for _ in range(N)]

for i in range(N):
    for j in range(N):
        x1, y1 = nodes[i]
        x2, y2 = nodes[j]
        dist[i][j] = math.sqrt((x1-x2)**2 + (y1-y2)**2)


def tour_cost(tour, dist):

    cost = 0
    n = len(tour)

    for i in range(n - 1):
        cost += dist[tour[i]][tour[i + 1]]

    cost += dist[tour[-1]][tour[0]]

    return cost


NUM_AGENTS = 30


class Agent:

    def __init__(self, start_node):
        self.path = [start_node]
        self.active = True


def create_population(num_agents, n_nodes):

    agents = []

    for _ in range(num_agents):

        start = random.randint(0, n_nodes - 1)

        agent = Agent(start)

        agents.append(agent)

    return agents


agents = create_population(NUM_AGENTS, N)

def get_available_nodes(agent, n_nodes):

    visited = set(agent.path)

    available = []

    for node in range(n_nodes):

        if node not in visited:

            available.append(node)

    return available


def extend_agent(agent, n_nodes):

    available = get_available_nodes(agent, n_nodes)

    if not available:

        return
    
    next_node = random.choice(available)

    agent.path.append(next_node)

def grow_agents(agents, n_nodes):

    for agent in agents:

        if agent.active:

            extend_agent(agent, n_nodes)


def get_edges(agent):

    edges = set()

    path = agent.path

    for i in range(len(path) - 1):

        a = path[i]
        b = path[i + 1]

        edge = tuple(sorted((a, b)))

        edges.add(edge)

    return edges


def edge_similarity(a1, a2):

    e1 = get_edges(a1)
    e2 = get_edges(a2)

    common = e1.intersection(e2)

    return len(common)


def should_merge(a1, a2, n_nodes):

    threshold = max(1, int(nodes * 0.05))

    common = edge_similarity(a1, a2)

    return common >= threshold

def two_opt(agent, dist):

    path = agent.path[:]

    best_cost = tour_cost(path, dist)

    improved = True

    while improved:

        improved = False

        for i in range(1, len(path) - 2):

            for j in range(i + 1, len(path)):

                if j - i == 1:

                    continue
                new_path = path[:]

                new_path[i:j] = reversed(path[i:j])

                new_cost = tour_cost(new_path, dist)

                if new_cost < best_cost:

                    path = new_path
                    best_cost = new_cost
                    improved = True

        agent.path = path



